{
    "version": "1.0",
    "label_registry": [
        {
            "label": "notes_column",
            "display_name": "General Notes Column",
            "color": "#1ea01e",
            "description": "Numbered or bulleted construction notes block. Contains requirements, material callouts, or code references. Usually in right margin or bottom zone.",
            "aliases": [
                "notes",
                "general notes",
                "keynotes"
            ],
            "expected_zones": [
                "right_margin",
                "bottom_band"
            ],
            "text_patterns": [
                "^\\d+\\.",
                "^•",
                "SHALL",
                "PER CODE",
                "ALL.*SHALL"
            ],
            "typical_font_size_range": [
                6.0,
                10.0
            ],
            "typical_is_all_caps": false,
            "distinguishing_features": [
                "high token count",
                "sequential numbering",
                "small font"
            ],
            "commonly_confused_with": [
                "header",
                "legend"
            ]
        },
        {
            "label": "header",
            "display_name": "Section or View Header",
            "color": "#dc1e1e",
            "description": "Bold large-font label identifying a drawing view, section, or major sheet area.",
            "aliases": [
                "title",
                "view label",
                "section title"
            ],
            "expected_zones": [
                "header_band",
                "drawing_area"
            ],
            "text_patterns": [
                "^[A-Z\\s/\\-]+$",
                "PLAN",
                "ELEVATION",
                "SECTION",
                "DETAIL"
            ],
            "typical_font_size_range": [
                10.0,
                24.0
            ],
            "typical_is_all_caps": true,
            "distinguishing_features": [
                "short token count",
                "large font",
                "bold"
            ],
            "commonly_confused_with": [
                "notes_column",
                "misc_title"
            ]
        },
        {
            "label": "abbreviations",
            "display_name": "Abbreviations Table",
            "color": "#e05096",
