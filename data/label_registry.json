            "typical_font_size_range": [
                6.0,
                9.0
            ],
            "typical_is_all_caps": true,
            "distinguishing_features": [
                "two-column layout",
                "short codes",
                "equal or colon delimiters"
            ],
            "commonly_confused_with": [
                "legend",
                "notes_column"
            ]
        },
        {
            "label": "legend",
            "display_name": "Legend / Symbol Key",
